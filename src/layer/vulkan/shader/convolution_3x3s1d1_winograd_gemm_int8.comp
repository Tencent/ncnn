#elif ncnn_VK_KHR_shader_integer_dot_product && ncnn_shaderIntegerDotProduct && ncnn_integerDotProduct32BitSignedAccelerated
        for (int z4 = 0; z4 < LOCAL_MEMORY_UNROLL_INCH; z4 += 4)
        {
            const ivec4 v0 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 0], tmp_v[lx][(z4 + 1) * 4 + 0], tmp_v[lx][(z4 + 2) * 4 + 0], tmp_v[lx][(z4 + 3) * 4 + 0]);
            const ivec4 v1 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 1], tmp_v[lx][(z4 + 1) * 4 + 1], tmp_v[lx][(z4 + 2) * 4 + 1], tmp_v[lx][(z4 + 3) * 4 + 1]);
            const ivec4 v2 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 2], tmp_v[lx][(z4 + 1) * 4 + 2], tmp_v[lx][(z4 + 2) * 4 + 2], tmp_v[lx][(z4 + 3) * 4 + 2]);
            const ivec4 v3 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 3], tmp_v[lx][(z4 + 1) * 4 + 3], tmp_v[lx][(z4 + 2) * 4 + 3], tmp_v[lx][(z4 + 3) * 4 + 3]);

