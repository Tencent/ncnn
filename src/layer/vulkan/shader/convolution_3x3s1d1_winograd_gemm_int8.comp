            const i16vec4 v3 = i16vec4(int16_t(tmp_v[lx][(z4 + 0) * 4 + 3]), int16_t(tmp_v[lx][(z4 + 1) * 4 + 3]), int16_t(tmp_v[lx][(z4 + 2) * 4 + 3]), int16_t(tmp_v[lx][(z4 + 3) * 4 + 3]));

            const i16vec4 k0 = i16vec4(int16_t(tmp_k[ly][(z4 + 0) * 4 + 0]), int16_t(tmp_k[ly][(z4 + 1) * 4 + 0]), int16_t(tmp_k[ly][(z4 + 2) * 4 + 0]), int16_t(tmp_k[ly][(z4 + 3) * 4 + 0]));
            const i16vec4 k1 = i16vec4(int16_t(tmp_k[ly][(z4 + 0) * 4 + 1]), int16_t(tmp_k[ly][(z4 + 1) * 4 + 1]), int16_t(tmp_k[ly][(z4 + 2) * 4 + 1]), int16_t(tmp_k[ly][(z4 + 3) * 4 + 1]));
            const i16vec4 k2 = i16vec4(int16_t(tmp_k[ly][(z4 + 0) * 4 + 2]), int16_t(tmp_k[ly][(z4 + 1) * 4 + 2]), int16_t(tmp_k[ly][(z4 + 2) * 4 + 2]), int16_t(tmp_k[ly][(z4 + 3) * 4 + 2]));
            const i16vec4 k3 = i16vec4(int16_t(tmp_k[ly][(z4 + 0) * 4 + 3]), int16_t(tmp_k[ly][(z4 + 1) * 4 + 3]), int16_t(tmp_k[ly][(z4 + 2) * 4 + 3]), int16_t(tmp_k[ly][(z4 + 3) * 4 + 3]));

            sum0.r += dotEXT(v0, k0);
            sum0.g += dotEXT(v0, k1);
            sum0.b += dotEXT(v0, k2);
            sum0.a += dotEXT(v0, k3);

            sum1.r += dotEXT(v1, k0);
            sum1.g += dotEXT(v1, k1);
            sum1.b += dotEXT(v1, k2);
            sum1.a += dotEXT(v1, k3);

            sum2.r += dotEXT(v2, k0);
            sum2.g += dotEXT(v2, k1);
            sum2.b += dotEXT(v2, k2);
            sum2.a += dotEXT(v2, k3);

            sum3.r += dotEXT(v3, k0);
            sum3.g += dotEXT(v3, k1);
            sum3.b += dotEXT(v3, k2);
            sum3.a += dotEXT(v3, k3);
        }

        for (; z4 < remain; z4++)
        {
            const ivec4 v = ivec4(tmp_v[lx][z4 * 4 + 0], tmp_v[lx][z4 * 4 + 1], tmp_v[lx][z4 * 4 + 2], tmp_v[lx][z4 * 4 + 3]);
            const ivec4 k = ivec4(tmp_k[ly][z4 * 4 + 0], tmp_k[ly][z4 * 4 + 1], tmp_k[ly][z4 * 4 + 2], tmp_k[ly][z4 * 4 + 3]);

            sum0 += v.r * k;
            sum1 += v.g * k;
            sum2 += v.b * k;
            sum3 += v.a * k;
        }
#elif ncnn_VK_KHR_shader_integer_dot_product && ncnn_shaderIntegerDotProduct && ncnn_integerDotProduct32BitSignedAccelerated
        int z4 = 0;
        for (; z4 + 3 < remain; z4 += 4)
        {
            const ivec4 v0 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 0], tmp_v[lx][(z4 + 1) * 4 + 0], tmp_v[lx][(z4 + 2) * 4 + 0], tmp_v[lx][(z4 + 3) * 4 + 0]);
            const ivec4 v1 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 1], tmp_v[lx][(z4 + 1) * 4 + 1], tmp_v[lx][(z4 + 2) * 4 + 1], tmp_v[lx][(z4 + 3) * 4 + 1]);
            const ivec4 v2 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 2], tmp_v[lx][(z4 + 1) * 4 + 2], tmp_v[lx][(z4 + 2) * 4 + 2], tmp_v[lx][(z4 + 3) * 4 + 2]);
            const ivec4 v3 = ivec4(tmp_v[lx][(z4 + 0) * 4 + 3], tmp_v[lx][(z4 + 1) * 4 + 3], tmp_v[lx][(z4 + 2) * 4 + 3], tmp_v[lx][(z4 + 3) * 4 + 3]);

            const ivec4 k0 = ivec4(tmp_k[ly][(z4 + 0) * 4 + 0], tmp_k[ly][(z4 + 1) * 4 + 0], tmp_k[ly][(z4 + 2) * 4 + 0], tmp_k[ly][(z4 + 3) * 4 + 0]);
            const ivec4 k1 = ivec4(tmp_k[ly][(z4 + 0) * 4 + 1], tmp_k[ly][(z4 + 1) * 4 + 1], tmp_k[ly][(z4 + 2) * 4 + 1], tmp_k[ly][(z4 + 3) * 4 + 1]);
            const ivec4 k2 = ivec4(tmp_k[ly][(z4 + 0) * 4 + 2], tmp_k[ly][(z4 + 1) * 4 + 2], tmp_k[ly][(z4 + 2) * 4 + 2], tmp_k[ly][(z4 + 3) * 4 + 2]);
            const ivec4 k3 = ivec4(tmp_k[ly][(z4 + 0) * 4 + 3], tmp_k[ly][(z4 + 1) * 4 + 3], tmp_k[ly][(z4 + 2) * 4 + 3], tmp_k[ly][(z4 + 3) * 4 + 3]);

