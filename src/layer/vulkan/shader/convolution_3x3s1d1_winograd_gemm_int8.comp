            const ivec4 k = ivec4(tmp_k[ly][z4 * 4 + 0], tmp_k[ly][z4 * 4 + 1], tmp_k[ly][z4 * 4 + 2], tmp_k[ly][z4 * 4 + 3]);

            sum0 += v.r * k;
            sum1 += v.g * k;
            sum2 += v.b * k;
            sum3 += v.a * k;
